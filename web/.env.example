# Frontend Environment Variables (Local & Vercel)

# MongoDB Connection (Required for API routes)
MONGODB_URI=your_mongodb_atlas_uri

# Supabase Auth (Client-side)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay Webhook (Optional)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Production API URL (Set to your Vercel deployment URL)
NEXT_PUBLIC_API_URL=https://your-frontend-site.vercel.app
